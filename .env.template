# Google Custom Search API
# To enable: https://console.cloud.google.com/apis/library/customsearch.googleapis.com
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_google_cse_id_here

# Together AI (free tier - used for executor, verifier, generator, judge)
# Model: Qwen/Qwen2.5-7B-Instruct-Turbo (serverless, no dedicated endpoint needed)
TOGETHER_API_KEY=your_together_api_key_here

# OpenAI (set to dummy - not needed unless using GPT models)
OPENAI_API_KEY=dummy

# Modal planner endpoint (set after running: modal deploy modal_deploy/serve_planner.py)
# Example: PLANNER_BASE_URL=https://your-org--agentflow-planner-serve.modal.run/v1
# PLANNER_BASE_URL=

# Spider database path (for Text-to-SQL benchmark, Step 4)
